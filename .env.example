# === OpenRouter（推荐）===
# 设置后自动使用 deepseek/deepseek-v3.2 作为 LLM，openai/text-embedding-3-small 作为 Embedding
OPENROUTER_API_KEY=your_openrouter_key_here

# === OpenAI（备用）===
# 若未设置 OPENROUTER_API_KEY，则回退到 OpenAI
# CHATGPT_API_KEY=your_openai_key_here

# === 自定义覆盖（可选）===
# RAG_MODEL=deepseek/deepseek-v3.2
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=your_key_here

# === 数据库 ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pageindex_rag
CHROMA_PERSIST_DIR=./chroma_data
